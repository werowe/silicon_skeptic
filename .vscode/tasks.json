{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CUDA: build active file",
      "type": "shell",
      "command": "nvcc",
      "args": [
        "-std=c++17",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "CUDA: build and run active file",
      "type": "shell",
      "command": "sh",
      "args": [
        "-c",
        "nvcc -std=c++17 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\""
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}